# Database (optional). If POSTGRES_NAME is set, Postgres is used instead of SQLite.
POSTGRES_NAME=backend
POSTGRES_USER=backend
POSTGRES_PASSWORD=backend
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Firebase / FCM
# FCM_SERVER_KEY is required to send push notifications via FCM.
FCM_SERVER_KEY=
# If not set, the backend looks for wino_backend/firebase-adminsdk.json.
GOOGLE_APPLICATION_CREDENTIALS=/code/firebase-adminsdk.json

# Recommendations
RECOMMENDATION_EXPLORATION_RATE=0.10

# Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Twilio OTP (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Allowed values: whatsapp | sms | both
TWILIO_OTP_CHANNEL=whatsapp
